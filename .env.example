PORT=4000
DATABASE_URL=postgresql://beam0:beam0@localhost:5432/beam0
# Required for docker-compose.prod.yml (Hetzner) — must match DATABASE_URL password
POSTGRES_PASSWORD=beam0
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_in_production_min_32_chars
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Beam0 <noreply@beam0.app>
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=
APP_URL=http://localhost:3000
FIREBASE_SERVICE_ACCOUNT_JSON=
# Uploads are stored locally at web/backend/uploads/
# No cloud storage needed for local/dev
NODE_ENV=development
# Comma-separated list of allowed CORS origins (production only). Dev allows all.
CORS_ORIGINS=https://beam0.app,https://www.beam0.app
