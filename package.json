{
  "name": "beam0-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "migrate": "node src/db/migrate.js",
    "test": "node --test --test-concurrency=1 --test-reporter=spec $(find src -name '*.test.js' | sort)",
    "test:unit": "node --test --test-reporter=spec $(find src/middleware src/services -name '*.test.js' | sort)",
    "test:integration": "node --test --test-concurrency=1 --test-reporter=spec $(find src/routes src/__tests__/integration -name '*.test.js' | sort)",
    "test:watch": "node --test --watch --test-concurrency=1 $(find src -name '*.test.js' | sort)"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@sentry/node": "^8.0.0",
    "bullmq": "^5.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "pg": "^8.12.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "stripe": "^16.2.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0"
  }
}
